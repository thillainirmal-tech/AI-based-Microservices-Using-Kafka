# =============================================================
# .env.example — fraud-detection-system
#
# USAGE:
#   cp .env.example .env
#   Then fill in your real values in .env
#
# WARNING:
#   .env is git-ignored and must NEVER be committed.
#   Only .env.example (with dummy values) lives in version control.
# =============================================================

# ── Spring Profile ────────────────────────────────────────────
# "docker" → uses container service names (kafka, redis, mysql)
# "local"  → uses localhost for all infrastructure
SPRING_PROFILES_ACTIVE=docker

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong random secret (min 32 chars).
# Example: openssl rand -base64 48
JWT_SECRET=change_me_use_a_long_random_secret_min_32_chars
JWT_EXPIRATION_MS=86400000

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# ── Kafka ─────────────────────────────────────────────────────
# In Docker mode, Kafka is accessed via internal Docker network name.
# Do NOT change these unless you rename the kafka container.
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_DLQ=transactions.DLT
KAFKA_TOPIC_NOTIFICATIONS=notifications

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── OpenAI ───────────────────────────────────────────────────
# Required for Layer 3 AI fraud analysis.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ── Razorpay (Payment Gateway) ────────────────────────────────
# Required only when RAZORPAY_ENABLED=true.
# Get test keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (SMTP via Gmail) ────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars

# ── Internal Service URLs (Docker network) ────────────────────
# These use Docker Compose service names — do not change for Docker mode.
AUTH_SERVICE_URL=http://auth-service:8083
TRANSACTION_SERVICE_URL=http://transaction-service:8081
FRAUD_SERVICE_URL=http://fraud-detection-service:8082
BANK_SERVICE_URL=http://bank-service:8084

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Fraud Detection Thresholds ────────────────────────────────
# All configurable — no code changes needed to tune detection sensitivity.
FRAUD_HIGH_AMOUNT_THRESHOLD=10000
FRAUD_MAX_TX_PER_DAY=10
FRAUD_IMPOSSIBLE_TRAVEL_MIN=5
FRAUD_REVIEW_CONF_MIN=0.4
FRAUD_REVIEW_CONF_MAX=0.6
FRAUD_RESULT_TTL_HOURS=72

# ── Rate Limiting (Transaction Service) ───────────────────────
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60
